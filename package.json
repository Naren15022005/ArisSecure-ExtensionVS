{
  "name": "aris-code",
  "displayName": "Aris Code",
  "description": "Security-first code generation for VSCode",
  "version": "0.2.0",
  "publisher": "alfonsito",
  "engines": {
    "vscode": "^1.60.0",
    "node": "^18.0.0"
  },
  "categories": ["AI", "Code Generators", "Testing"],
  "keywords": ["ai", "code-generation", "security", "semgrep", "ollama"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "arisCode.generate",
        "title": "Aris: Generate Secure Code",
        "category": "Aris Code"
      },
      {
        "command": "arisCode.scanFile",
        "title": "Aris: Scan Current File",
        "category": "Aris Code"
      },
      {
        "command": "arisCode.quickScan",
        "title": "Aris: Quick Scan",
        "category": "Aris Code",
        "icon": "$(shield)"
      },
      {
        "command": "arisCode.goToIssue",
        "title": "Aris: Go To Issue",
        "category": "Aris Code"
      },
      {
        "command": "arisCode.applyFix",
        "title": "Aris: Apply Fix",
        "category": "Aris Code"
      },
      {
        "command": "arisCode.copyAllIssues",
        "title": "Aris: Copy All Issues",
        "category": "Aris Code",
        "icon": "$(copy)"
      },
      {
        "command": "arisCode.showRelationships",
        "title": "Aris: Show Issue Relationships",
        "category": "Aris Code",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "arisCode.suggestFix",
        "title": "Aris: Suggest Fix",
        "category": "Aris Code",
        "icon": "$(lightbulb)"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+shift+alt+g",
        "command": "arisCode.generate",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+shift+alt+s",
        "mac": "cmd+shift+alt+s",
        "command": "arisCode.scanFile",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+shift+alt+q",
        "mac": "cmd+shift+alt+q",
        "command": "arisCode.quickScan",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "arisCode.quickScan",
          "group": "navigation",
          "when": "editorTextFocus"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "arisCode-explorer",
          "title": "Aris Code",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "arisCode-explorer": [
        {
          "id": "arisCode-issues",
          "name": "Security Issues"
        }
      ]
    },
    "configuration": {
      "title": "Aris Code",
      "properties": {
        "arisCode.llmProvider": {
          "type": "string",
          "enum": ["ollama", "openai"],
          "default": "ollama",
          "description": "LLM provider for code generation"
        },
        "arisCode.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "arisCode.ollamaModel": {
          "type": "string",
          "default": "llama2",
          "description": "Ollama model name"
        },
        "arisCode.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Generation temperature"
        },
        "arisCode.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key"
        },
        "arisCode.semgrepApiToken": {
          "type": "string",
          "default": "",
          "description": "Semgrep API token (optional)"
        }
      }
    }
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "esbuild": "^0.19.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node",
    "build:cli": "esbuild ./src/cli/ArisSecureCLI.ts --bundle --outfile=dist/cli.js --platform=node --external:vscode",
    "arisecure:scan": "node dist/cli.js --path ./src --format text",
    "arisecure:scan:json": "node dist/cli.js --path ./src --format json --output scan-report.json",
    "arisecure:scan:critical": "node dist/cli.js --path ./src --severity critical --format text",
    "dev": "npm run build -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "package": "vsce package",
    "publish": "vsce publish",
    "clean": "rimraf dist out"
  }
}
