{
  "name": "aris-code",
  "displayName": "Aris Code",
  "description": "Security-first code generation for VSCode",
  "version": "0.1.0",
  "publisher": "alfonsito",
  "engines": {
    "vscode": "^1.60.0",
    "node": "^18.0.0"
  },
  "categories": ["AI", "Code Generators", "Testing"],
  "keywords": ["ai", "code-generation", "security", "semgrep", "ollama"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "arisCode.generate",
        "title": "Aris: Generate Secure Code",
        "category": "Aris Code"
      },
      {
        "command": "arisCode.scanFile",
        "title": "Aris: Scan Current File",
        "category": "Aris Code"
      }
    ],
    "configuration": {
      "title": "Aris Code",
      "properties": {
        "arisCode.llmProvider": {
          "type": "string",
          "enum": ["ollama", "openai"],
          "default": "ollama",
          "description": "LLM provider for code generation"
        },
        "arisCode.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "arisCode.ollamaModel": {
          "type": "string",
          "default": "llama2",
          "description": "Ollama model name"
        },
        "arisCode.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Generation temperature"
        },
        "arisCode.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key"
        },
        "arisCode.semgrepApiToken": {
          "type": "string",
          "default": "",
          "description": "Semgrep API token (optional)"
        }
      }
    },
    "keybindings": [
      {
        "key": "ctrl+shift+alt+g",
        "command": "arisCode.generate",
        "when": "editorTextFocus"
      }
    ]
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "esbuild": "^0.19.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node",
    "dev": "npm run build -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "package": "vsce package",
    "publish": "vsce publish",
    "clean": "rimraf dist out"
  }
}
